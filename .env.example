# LLM API Key（支持任何 OpenAI 兼容的服务）
# Gemini: 从 https://aistudio.google.com/app/apikey 获取
# ModelScope: 从 https://modelscope.cn/my/access/token 获取
LLM_API_KEY=your_api_key_here

# LLM API 基础地址（默认使用 Gemini 的 OpenAI 兼容端点）
LLM_API_BASE=https://generativelanguage.googleapis.com/v1beta/openai

# LLM 模型名称
LLM_MODEL_NAME=gemini-2.5-flash

# 备选配置示例（SiliconFlow）
# LLM_API_BASE=https://api.siliconflow.cn/v1
# LLM_MODEL_NAME=Qwen/Qwen2.5-7B-Instruct

# 备选配置示例（DeepSeek）
# LLM_API_BASE=https://api.deepseek.com/v1
# LLM_MODEL_NAME=deepseek-chat

# 本地 Ollama（OpenAI 兼容，可先 ollama pull 模型）
# LLM_API_BASE=http://127.0.0.1:11434/v1
# LLM_MODEL_NAME=qwen2.5:7b
# OpenAI 兼容客户端要求非空 api_key；正式对话与 API 请在 .env 中显式设置，例如：
# LLM_API_KEY=ollama
# 仅运行 evals/rag/eval_rag.py 时，若 Key 为空且检测到本机 Ollama 风格地址，脚本会临时使用占位符 ollama（不影响上述正式链路要求）。

# Agent 模式（LangGraph + Skills）：为 true/1 时，**强制在终端 stderr** 打印每轮决策/生成/流式的完整
# system、user、assistant，以及模型返回的 tool_calls、每次 skill 执行入参与返回 JSON（不依赖 uvicorn 日志级别）。
# 由 core.config.Settings 从本文件读取（字段 cfn_agent_debug_llm）。
# CFN_AGENT_DEBUG_LLM=1
